
# Получите токен у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# Порт для локального Mini App (веб-каталога магазина)
WEBAPP_PORT=8080

# URL, по которому доступен Mini App снаружи (для BotFather).
# При запуске на ПК используйте любой туннель: ngrok, serveo, cloudflared и т.д.
# Например: https://xxxx.ngrok-free.app
WEBAPP_URL=https://your-ngrok-url.ngrok-free.app

# ID администратора (узнать у @userinfobot)
ADMIN_ID=123456789
